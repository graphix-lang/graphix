// Naive fibonacci — non-tail recursion. Fuses to a recursive Rust fn
// (rustc may emit TCO, or leave it as a regular recursive call).
let rec fib = |n: i64| -> i64
    select n {
        0 => 0,
        1 => 1,
        _ => fib(n - 1) + fib(n - 2)
    };

println("fib(10) = [fib(10)]");
println("fib(20) = [fib(20)]");
println("fib(30) = [fib(30)]");
sys::exit(0)
