// Collatz: count steps from n down to 1. Exercises self-recursion
// inside a select arm, mixed even/odd branches.
let rec collatz_len = |n: i64, steps: i64| -> i64
    select n {
        1 => steps,
        _ => select n % 2 {
            0 => collatz_len(n / 2, steps + 1),
            _ => collatz_len(3 * n + 1, steps + 1)
        }
    };

println("collatz_len(27, 0) = [collatz_len(27, 0)]");
println("collatz_len(97, 0) = [collatz_len(97, 0)]");
sys::exit(0)
