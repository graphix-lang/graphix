// Sum of squares from 1..=n. Tail-recursive with accumulator →
// should fuse to a Rust `loop`.
use array;

let rec sum_sq = |n: i64, acc: i64| -> i64
    select n {
        0 => acc,
        _ => sum_sq(n - 1, acc + n * n)
    };

println("sum_sq(100, 0) = [sum_sq(100, 0)]");
println("sum_sq(1000, 0) = [sum_sq(1000, 0)]");
sys::exit(0)
