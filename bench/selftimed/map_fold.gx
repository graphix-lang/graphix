// Composed HOFs: map (*3) then fold (+) over 100k elements. The JIT
// fuses both into a single kernel with two loops and no intermediate
// array materialized at the language boundary.
{
  let n = i64:100000;
  let t0 = sys::time::now(i64:0);
  let seed = cast<i64>(t0)$;
  let result = array::fold(array::map(array::init(n, |i| i), |x| x * i64:3), seed, |a, x| a + x);
  let t1 = result ~ sys::time::now(result);
  let elapsed = t1 ~ (cast<f64>(t1)$ - cast<f64>(t0)$);
  println("map_fold n=[n] result=[result] elapsed_s=[elapsed]");
  sys::exit(elapsed ~ i64:0)
}
