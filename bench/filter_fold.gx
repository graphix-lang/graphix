// filter (even) then fold (+) over 100k elements. The filter's keep/drop
// decision and the reduction fuse into one native kernel.
let n = 100000;
let t0 = sys::time::now(0);
let seed = cast<i64>(t0)$;
let result = array::fold(array::filter(array::init(n, |i| i), |x| x % 2 == 0), seed, |a, x| a + x);
let t1 = sys::time::now(result);
let elapsed = cast<f64>(t1)$ - cast<f64>(t0)$;
println("filter_fold n=[n] result=[result] elapsed_s=[elapsed]");
sys::exit(elapsed ~ 0)
