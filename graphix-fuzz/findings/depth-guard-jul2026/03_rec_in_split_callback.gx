{let v0 = array::fold([i64:-1], i64:255, |v1, v0| {let rec v2 = |v3: i64, v4: i64| -> i64 select v3 {i64:0 => v4, _ => v2(v3 - i64:1, v4 + v3)}; (v2(i64:256, i64:0) * i64:0) + (try ((v0 /? i64:-1))? catch(e) => i64:42)}); [i64:7 + v0]}
