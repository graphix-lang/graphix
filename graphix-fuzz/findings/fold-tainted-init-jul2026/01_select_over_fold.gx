// The original witness shape: the recovering fold feeds a select —
// the bind-all arm fires in both modes (0.9), guards and all.
{
  let rec v1 = |v3: i64| -> i64 select v3 {v4 if v4 <= i64:0 => (i64:1 % v4), v4 => v1(v4 - i64:1)};
  let v5 = v1(i64:9);
  select array::fold([i64:1, i64:100, i64:-100], v5, |v13, v16| v16) {
    i64:-1 if (!false) => f64:3.14,
    i64:0 if (f64:0.1 != f64:3.14) => f64:0.,
    i64:-1 => (f64:-1. % (-(f64:-1.))),
    v16 => (f64:1. + (-(f64:0.1)))
  }
}
