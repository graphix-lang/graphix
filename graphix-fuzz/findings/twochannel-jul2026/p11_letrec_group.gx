{let a = array::init(array::iter([i64:0, i64:2, i64:3, i64:4]), |i| i + i64:1); let f = array::fold(a, i64:0, |acc, x| {let rec iterate = |zr: f64, zi: f64, cr: f64, ci: f64, i: i64| -> i64 select i {i64:0 => i64:0, _ if zr * zr + zi * zi > f64:4. => i, _ => iterate(zr * zr - zi * zi + cr, f64:2. * zr * zi + ci, cr, ci, i - i64:1)}; iterate(f64:0., f64:0., f64:1., f64:0., i64:10)}); array::group(f, |n, _| n == i64:4)}
