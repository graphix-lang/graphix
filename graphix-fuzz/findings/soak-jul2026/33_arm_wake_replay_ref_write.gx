{let v0 = [i64:0, i64:0, i64:42]; let v1 = select v0 {[_, v1..] if (!false) => ((i64:0 /? i64:100)$ / v0[i64:0]$), [v1, v2..] => array::fold([i64:-1, i64:2, i64:42], v1, |v0, v3| v1), v1 => v1[i64:0]$}; let v4 = |v2, v3| ((v3 + v3) + v3); let v5 = v4(f64:2.5, f64:0.1); let v6 = v4(i64:42, i64:7); let v1 = |v7: i64| select v7 {i64:0 => "", _ => error(false)}; let v8 = v1(i64:1)$; let v9 = &v8; *v9 <- "xyz"; select v0 {[v7] => ["", "", "graphix"], _ => [v8]}}
