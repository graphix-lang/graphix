// bisect: fusion/JIT bug (interp != jit)
// interp: Trace(Trace { epochs: [Epoch { events: [(0, I64(1))], capped: false }, Epoch { events: [(0, I64(0)), (1, I64(6))], capped: false }, Epoch { events: [(0, I64(1))], capped: false }, Epoch { events: [(0, I64(0)), (1, I64(6))], capped: false }, Epoch { events: [], capped: false }] })
// jit:    Trace(Trace { epochs: [Epoch { events: [(0, I64(1))], capped: false }, Epoch { events: [(0, I64(0)), (1, I64(6))], capped: false }, Epoch { events: [(0, I64(1))], capped: false }, Epoch { events: [(0, I64(6))], capped: false }, Epoch { events: [], capped: false }] })
// mutant: // schedule-v1: cap=64 events=512; in0=i64:1; in0=i64:2; in0=i64:3; in0=i64:1\nselect i64:0 {i64:0 if in0 % i64:2 == i64:0 => i64:1, _ => {let a = [i64:1, i64:2, i64:3]; let s = i64:0; s <- array::fold(a, i64:0, |acc, e| acc + e); s}}
// minimized:
// schedule-v1: cap=64 events=512; in0=i64:1; in0=i64:0; in0=i64:1
select i64:0 {i64:0 if in0 % i64:2 == i64:0 => null, _ => {let a = [i64:1, i64:2, i64:3]; let s = i64:0; s <- array::fold(a, i64:0, |acc, e| acc + e); s}}
