{
  "grammars": [
    {
      "name": "graphix",
      "camelcase": "Graphix",
      "scope": "source.graphix",
      "path": ".",
      "file-types": [
        "gx",
        "gxi"
      ],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm"
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Graphix programming language",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-graphix"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
