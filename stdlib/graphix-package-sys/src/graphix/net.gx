let write = |path, value| 'sys_net_write;
let subscribe = |path| 'sys_net_subscribe;
let call = |path, args| 'sys_net_call;
let rpc = |#path, #doc, #spec, #f| 'sys_net_publish_rpc;
let list = |#update = sys::time::timer(1, true), path| 'sys_net_list;
let list_table = |#clock = sys::time::timer(1, true), path| 'sys_net_list_table;
let publish = |#on_write = |v| never(v), path, v| 'sys_net_publish
