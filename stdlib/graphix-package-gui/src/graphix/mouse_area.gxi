type MouseArea = {
  child: &Widget,
  on_press: &fn(null) -> Any,
  on_release: &fn(null) -> Any,
  on_enter: &fn(null) -> Any,
  on_exit: &fn(null) -> Any,
  on_move: &fn({x: f64, y: f64}) -> Any
};

val mouse_area: fn(
  ?#on_press: fn(null) -> Any,
  ?#on_release: fn(null) -> Any,
  ?#on_enter: fn(null) -> Any,
  ?#on_exit: fn(null) -> Any,
  ?#on_move: fn({x: f64, y: f64}) -> Any,
  &Widget
) -> Widget
