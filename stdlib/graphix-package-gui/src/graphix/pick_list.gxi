type PickList = {
  disabled: &bool,
  on_select: &fn(s: string) -> Any,
  options: &Array<string>,
  selected: &[string, null],
  placeholder: &string,
  width: &Length,
  padding: &Padding
};

val pick_list: fn(
  ?#selected: &[string, null],
  ?#on_select: fn(s: string) -> Any,
  ?#placeholder: &string,
  ?#width: &Length,
  ?#padding: &Padding,
  ?#disabled: &bool,
  options: &Array<string>
) -> Widget
