type PickList = {
  on_select: &fn(string) -> Any,
  options: &Array<string>,
  selected: &[string, null],
  placeholder: &string,
  width: &Length,
  padding: &Padding
};

val pick_list: fn(
  ?#selected: &[string, null],
  ?#on_select: fn(string) -> Any,
  ?#placeholder: &string,
  ?#width: &Length,
  ?#padding: &Padding,
  &Array<string>
) -> Widget
