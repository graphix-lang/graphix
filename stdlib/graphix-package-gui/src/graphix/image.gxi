type ImageSource = [string, `Path(string), `Bytes(bytes), `Rgba({width: u32, height: u32, pixels: bytes})];

type Image = {
  source: &ImageSource,
  width: &Length,
  height: &Length,
  content_fit: &ContentFit
};

val image: fn(
  ?#width: &Length,
  ?#height: &Length,
  ?#content_fit: &ContentFit,
  &ImageSource
) -> Widget
