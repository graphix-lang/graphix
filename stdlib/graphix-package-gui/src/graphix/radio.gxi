type Radio = {
  disabled: &bool,
  value: &Any,
  label: &string,
  on_select: &fn(Any) -> Any,
  selected: &Any,
  width: &Length,
  size: &[f64, null],
  spacing: &[f64, null]
};

val radio: fn(
  #label: &string,
  ?#selected: &Any,
  ?#on_select: fn(Any) -> Any,
  ?#width: &Length,
  ?#size: &[f64, null],
  ?#spacing: &[f64, null],
  ?#disabled: &bool,
  &Any
) -> Widget
