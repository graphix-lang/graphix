type Radio = {
  value: &Any,
  label: &string,
  on_select: &fn(Any) -> Any,
  selected: &[Any, null],
  width: &Length,
  size: &[f64, null],
  spacing: &[f64, null]
};

val radio: fn(
  #label: &string,
  ?#selected: &[Any, null],
  ?#on_select: fn(Any) -> Any,
  ?#width: &Length,
  ?#size: &[f64, null],
  ?#spacing: &[f64, null],
  &Any
) -> Widget
