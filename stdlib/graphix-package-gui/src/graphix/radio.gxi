type Radio = {
  disabled: &bool,
  value: &'a,
  label: &string,
  on_select: &fn(v: 'a) -> Any,
  selected: &['a, null],
  width: &Length,
  size: &[f64, null],
  spacing: &[f64, null]
};

val radio: fn(
  #label: &string,
  ?#selected: &['a, null],
  ?#on_select: fn(v: 'a) -> Any,
  ?#width: &Length,
  ?#size: &[f64, null],
  ?#spacing: &[f64, null],
  ?#disabled: &bool,
  value: &'a
) -> Widget
