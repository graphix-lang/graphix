type ComboBox = {
  on_select: &fn(string) -> Any,
  options: &Array<string>,
  selected: &[string, null],
  placeholder: &string,
  width: &Length
};

val combo_box: fn(
  ?#selected: &[string, null],
  ?#on_select: fn(string) -> Any,
  ?#placeholder: &string,
  ?#width: &Length,
  &Array<string>
) -> Widget
