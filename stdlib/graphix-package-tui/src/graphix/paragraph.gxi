/// `scroll.y` is in lines and `scroll.x` is in chars; `trim` drops
/// leading whitespace when wrapping.
type Paragraph = {
  alignment: &[Alignment, null],
  lines: &[Array<Line>, string],
  scroll: &{ x: i64, y: i64 },
  style: &Style,
  trim: &bool
};

val paragraph: fn(
  ?#style: &Style,
  ?#alignment: &[Alignment, null],
  ?#scroll: &{x: i64, y: i64},
  ?#trim: &bool,
  lines: &[Array<Line>, string]
) -> Tui;
