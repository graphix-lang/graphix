use sys;

let table = net::list_table("/local/bench")$;
let columns = array::filter(table.columns, |c| c != "sum");
let table = uniq({ table with columns });
array::map(table.rows, |row| {
  let sum = array::fold(table.columns, v64:0, |acc, c|
    acc + net::subscribe("[row]/[c]")$
  );
  net::publish("[row]/sum", sum)
})
